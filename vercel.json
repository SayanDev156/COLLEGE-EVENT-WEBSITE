{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "admin.html",
          "privacy.html",
          "terms.html",
          "styles.css",
          "script.js",
          "admin.js",
          "favicon.svg",
          "site.webmanifest",
          "robots.txt",
          "sitemap.xml",
          "assets/**",
          "data/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
